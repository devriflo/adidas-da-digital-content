          <div class="node-label">04 · Analytics</div>
          <div class="node-title">Campaign report kicked off</div>
          <div class="node-meta">Diva · CPU · Adobe</div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- =================== ACTIVITY =================== -->
