<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Global Digital Activation — Orchestrator</title>
<style>
  /* ---------- Brand fonts: adidas FG (official) ---------- */
  @font-face {
    font-family: "AdidasFG";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 400; font-style: italic; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 700; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 700; font-style: italic; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG Compressed";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG Compressed";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 700; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG Compressed";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 700; font-style: italic; font-display: swap;
  }
  @font-face {
    font-family: "AdidasFG Compressed";
    src: url("data:font/woff2;base64,") format("woff2");
    font-weight: 400; font-style: italic; font-display: swap;
  }

  /* ---------- Reset ---------- */
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; border: none; background: none; color: inherit; }

  /* ---------- Tokens (adidas brand) ---------- */
  :root {
    --bg: #ffffff;
    --ink: #000000;
    --ink-2: #1a1a1a;
    --muted: #6b6b6b;
    --line: #e6e6e6;
    --line-strong: #000000;
    --soft: #f5f5f5;
    --soft-2: #fafafa;
    --accent: #000000;
    --green: #00a862;
    --amber: #ffb000;
    --red:   #d62828;
    --blue:  #0057b7;
    /* Real adidas typefaces */
    --font-sans: "AdidasFG", "Helvetica Neue", Arial, system-ui, sans-serif;
    --font-display: "AdidasFG Compressed", "AdidasFG", "Helvetica Neue", Arial, sans-serif;
    --radius: 0px;       /* adidas brand: sharp corners */
    --radius-sm: 2px;
    --shadow: 0 1px 0 var(--line);
  }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
  }

  /* ---------- Layout ---------- */
  .wrap { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

  /* ---------- Top bar ---------- */
  .topbar {
    border-bottom: 1px solid var(--line);
    background: #fff;
    position: sticky; top: 0; z-index: 20;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .brand { display: flex; align-items: center; gap: 16px; }
  .brand-mark {
    height: 28px; display: inline-flex; align-items: center;
  }
  .brand-mark img { display: block; height: 28px; width: auto; }
  .brand-sep { width: 1px; height: 20px; background: var(--line); }
  .brand-product { font-weight: 700; letter-spacing: 0.02em; font-size: 14px; }

  .nav { display: flex; gap: 28px; }
  .nav a {
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; padding: 6px 0; position: relative;
    color: var(--muted);
  }
  .nav a.active { color: var(--ink); }
  .nav a.active::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: -22px;
    height: 2px; background: var(--ink);
  }

  .top-right { display: flex; align-items: center; gap: 16px; }
  .pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 10px; border: 1px solid var(--line);
    font-size: 12px; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .pulse {
    width: 8px; height: 8px; border-radius: 50%; background: var(--green);
    box-shadow: 0 0 0 0 rgba(0,168,98,.45);
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(0,168,98,.45); }
    70%  { box-shadow: 0 0 0 8px rgba(0,168,98,0); }
    100% { box-shadow: 0 0 0 0 rgba(0,168,98,0); }
  }
  .avatar {
    width: 32px; height: 32px; background: var(--ink); color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 12px; letter-spacing: 0.04em;
  }

  /* ---------- Hero ---------- */
  .hero { padding: 64px 0 40px; border-bottom: 1px solid var(--line); }
  .eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--muted);
    display: inline-flex; align-items: center; gap: 10px;
  }
  .eyebrow::before {
    content: ""; width: 24px; height: 2px; background: var(--ink);
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.92;
    letter-spacing: -0.015em;
    margin: 18px 0 16px;
    text-transform: uppercase;
    font-weight: 700;
  }
  .hero h1 span.slash { color: var(--muted); font-weight: 400; }
  .hero p.lede {
    max-width: 720px; font-size: 17px; color: var(--ink-2);
    margin: 0 0 28px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 22px; border: 1px solid var(--ink);
    font-size: 13px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; background: #fff; color: var(--ink);
    transition: transform .08s ease, background .15s ease, color .15s ease;
  }
  .btn:hover { background: var(--ink); color: #fff; }
  .btn:active { transform: translateY(1px); }
  .btn.primary { background: var(--ink); color: #fff; }
  .btn.primary:hover { background: #fff; color: var(--ink); }
  .btn .arrow { font-size: 15px; transform: translateY(-1px); }

  /* ---------- Status strip ---------- */
  .strip {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--line);
  }
  .stat {
    padding: 22px 24px;
    border-right: 1px solid var(--line);
  }
  .stat:last-child { border-right: none; }
  .stat-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
    color: var(--muted); text-transform: uppercase;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: 30px; font-weight: 700; letter-spacing: -0.01em;
    margin-top: 6px; line-height: 1;
  }
  .stat-delta { font-size: 12px; color: var(--muted); margin-top: 6px; }
  .stat-delta.up { color: var(--green); }
  .stat-delta.down { color: var(--red); }

  /* ---------- Section heading ---------- */
  .section { padding: 64px 0 24px; }
  .section-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 28px; gap: 24px; flex-wrap: wrap;
  }
  .section-head h2 {
    font-family: var(--font-display);
    font-size: 36px; line-height: 1; letter-spacing: -0.01em;
    font-weight: 700; text-transform: uppercase; margin: 0;
  }
  .section-head p { color: var(--muted); margin: 6px 0 0; max-width: 560px; }
  .section-head .meta {
    font-size: 12px; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  /* ---------- Agent grid ---------- */
  .agents { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; border: 1px solid var(--line); }
  .agent {
    padding: 32px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: #fff;
    position: relative;
    transition: background .15s ease;
    display: flex; flex-direction: column; min-height: 320px;
  }
  .agent:nth-child(2n) { border-right: none; }
  .agent:nth-last-child(-n+2) { border-bottom: none; }
  .agent:hover { background: var(--soft-2); }
  .agent-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .agent-num {
    font-family: var(--font-display);
    font-size: 13px; font-weight: 700; letter-spacing: 0.14em;
    color: var(--muted);
  }
  .agent-status {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); }
  .dot.idle { background: #c4c4c4; }
  .dot.run  { background: var(--green); animation: pulse 1.8s infinite; }
  .dot.warn { background: var(--amber); }

  .agent h3 {
    font-family: var(--font-display);
    font-size: 32px; line-height: 1.0; letter-spacing: -0.01em;
    text-transform: uppercase; font-weight: 700;
    margin: 18px 0 10px;
  }
  .agent p.desc { color: var(--ink-2); margin: 0 0 16px; max-width: 460px; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px; }
  .tag {
    font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 4px 8px;
    border: 1px solid var(--line); color: var(--ink-2);
  }
  .tag.live { border-color: var(--ink); background: var(--ink); color: #fff; }

  .agent-footer {
    margin-top: auto; display: flex; justify-content: space-between;
    align-items: center; gap: 16px; padding-top: 16px;
    border-top: 1px dashed var(--line);
  }
  .agent-meta { font-size: 12px; color: var(--muted); }
  .agent-meta strong { color: var(--ink); font-weight: 700; }
  .launch {
    font-size: 13px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 14px; border: 1px solid var(--ink); color: var(--ink); background: #fff;
  }
  .launch:hover { background: var(--ink); color: #fff; }

  /* ---------- Pipeline / Orchestrator visual ---------- */
  .orchestrator {
    padding: 32px;
    border: 1px solid var(--line);
    background: var(--soft-2);
    margin-top: 32px;
  }
  .pipeline {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 0;
    align-items: stretch;
    margin-top: 18px;
  }
  .node {
    padding: 18px 16px; background: #fff; border: 1px solid var(--line);
    display: flex; flex-direction: column; justify-content: space-between;
    min-height: 110px; position: relative;
  }
  .node.brain { background: var(--ink); color: #fff; border-color: var(--ink); }
  .node-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.7;
  }
  .node-title { font-weight: 700; font-size: 15px; margin-top: 6px; }
  .node-meta { font-size: 11px; margin-top: 10px; opacity: 0.7; letter-spacing: 0.04em; text-transform: uppercase; }
  .arrow-cell {
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); font-size: 18px;
  }

  /* ---------- Activity feed ---------- */
  .feed { border: 1px solid var(--line); }
  .feed-row {
    display: grid;
    grid-template-columns: 110px 180px 1fr 140px 100px;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }
  .feed-row:last-child { border-bottom: none; }
  .feed-row.head {
    background: var(--ink); color: #fff;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .feed-time { color: var(--muted); font-variant-numeric: tabular-nums; }
  .feed-agent { font-weight: 700; }
  .feed-status {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .feed-link {
    font-size: 12px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--ink); padding-bottom: 2px;
    justify-self: start;
  }

  /* ---------- Footer ---------- */
  footer {
    margin-top: 64px; border-top: 1px solid var(--line);
    padding: 24px 0 48px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12px; color: var(--muted); letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 960px) {
    .strip { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(-n+2) { border-bottom: 1px solid var(--line); }
    .agents { grid-template-columns: 1fr; }
    .agent { border-right: none !important; border-bottom: 1px solid var(--line) !important; }
    .agent:last-child { border-bottom: none !important; }
    .pipeline { grid-template-columns: 1fr; }
    .arrow-cell { transform: rotate(90deg); padding: 6px 0; }
    .feed-row { grid-template-columns: 90px 1fr; row-gap: 4px; }
    .feed-row .feed-desc, .feed-row .feed-status, .feed-row .feed-link { grid-column: 2; }
    .feed-row.head { display: none; }
    .nav { display: none; }
  }
</style>
</head>
<body>

<!-- =================== TOP BAR =================== -->
<header class="topbar">
  <div class="wrap topbar-inner">
    <div class="brand">
      <!-- Official adidas 3-bar Performance logo -->
      <span class="brand-mark" aria-label="adidas">
        <img src="data:image/png;base64," alt="adidas" />
      </span>
      <span class="brand-sep"></span>
      <span class="brand-product">Global Digital Activation</span>
    </div>

    <nav class="nav">
      <a href="#" class="active">Hub</a>
      <a href="#agents">Agents</a>
      <a href="#orchestrator">Orchestrator</a>
      <a href="#activity">Activity</a>
      <a href="#">Library</a>
    </nav>

    <div class="top-right">
      <span class="pill"><span class="pulse"></span> All systems live</span>
      <span class="avatar">FV</span>
    </div>
  </div>
</header>

<!-- =================== HERO =================== -->
<section class="hero">
  <div class="wrap">
    <span class="eyebrow">Internal — Global Digital Activation · 2026</span>
    <h1>
      Less ops.<br/>
      More <span class="slash">/</span> activation.
    </h1>
    <p class="lede">
      One orchestrator. Four specialised agents. Brief a campaign once and let the platform
      build your toolkit, crop the imagery, ship the Confluence page and report back on
      performance — automatically.
    </p>
    <div class="hero-actions">
      <button class="btn primary">Start a new campaign activation <span class="arrow">→</span></button>
      <button class="btn">Browse recent runs</button>
    </div>
  </div>
</section>

<!-- =================== STATUS STRIP =================== -->
<section class="strip">
  <div class="stat">
    <div class="stat-label">Active runs</div>
    <div class="stat-value">7</div>
    <div class="stat-delta up">▲ 3 since yesterday</div>
  </div>
  <div class="stat">
    <div class="stat-label">Hours saved · MTD</div>
    <div class="stat-value">142</div>
    <div class="stat-delta up">▲ 18% vs. April</div>
  </div>
  <div class="stat">
    <div class="stat-label">Toolkits shipped</div>
    <div class="stat-value">26</div>
    <div class="stat-delta">Across 9 markets</div>
  </div>
  <div class="stat">
    <div class="stat-label">Agent success rate</div>
    <div class="stat-value">98.4%</div>
    <div class="stat-delta up">▲ 1.2 pts</div>
  </div>
</section>

<!-- =================== AGENTS =================== -->
<section class="section" id="agents">
  <div class="wrap">
    <div class="section-head">
      <div>
        <span class="eyebrow">The squad</span>
        <h2>Agents on duty</h2>
        <p>Four specialised teammates. Trigger them individually, or chain them into a single brief from the orchestrator below.</p>
      </div>
      <span class="meta">Updated 2 min ago</span>
    </div>

    <div class="agents">

      <!-- Agent 01 — Confluence Composer -->
      <article class="agent">
        <div class="agent-head">
          <span class="agent-num">Agent · 01</span>
          <span class="agent-status"><span class="dot run"></span> Running · 1 job</span>
        </div>
        <h3>Confluence Composer</h3>
        <p class="desc">
          Drafts the activation Confluence page — formatted to the template, ready to publish.
        </p>
        <div class="tags">
          <span class="tag live">Confluence</span>
          <span class="tag">GDA template</span>
        </div>
        <div class="agent-footer">
          <div class="agent-meta"><strong>Last run:</strong> Originals × Wales Bonner · 1 hr ago</div>
          <button class="launch">Launch <span>→</span></button>
        </div>
      </article>

      <!-- Agent 02 — Image Cropper -->
      <article class="agent">
        <div class="agent-head">
          <span class="agent-num">Agent · 02</span>
          <span class="agent-status"><span class="dot idle"></span> Idle</span>
        </div>
        <h3>Image Cropper</h3>
        <p class="desc">
          Done with adigen.
        </p>
        <div class="tags">
          <span class="tag live">adigen</span>
        </div>
        <div class="agent-footer">
          <div class="agent-meta"><strong>Last run:</strong> 312 assets · 12 min ago</div>
          <button class="launch">Launch <span>→</span></button>
        </div>
      </article>

      <!-- Agent 03 — Digital Toolkit Builder -->
      <article class="agent">
        <div class="agent-head">
          <span class="agent-num">Agent · 03</span>
          <span class="agent-status"><span class="dot run"></span> Running · 2 jobs</span>
        </div>
        <h3>Digital Toolkit Builder</h3>
        <p class="desc">
          Creates the consumer journey in Figma based on the Airtable content plan and approved images.
        </p>
        <div class="tags">
          <span class="tag live">Figma MCP</span>
          <span class="tag live">Airtable</span>
          <span class="tag">Consumer journey</span>
        </div>
        <div class="agent-footer">
          <div class="agent-meta"><strong>Last run:</strong> SS26 Running Toolkit · 4 min ago</div>
          <button class="launch">Launch <span>→</span></button>
        </div>
      </article>

      <!-- Agent 04 — Campaign Reporting -->
      <article class="agent">
        <div class="agent-head">
          <span class="agent-num">Agent · 04</span>
          <span class="agent-status"><span class="dot warn"></span> Awaiting data</span>
        </div>
        <h3>Campaign Reporting</h3>
        <p class="desc">
          Pulls campaign performance from across data sources — Diva, CPU and Adobe Analytics —
          and turns it into a single campaign report.
        </p>
        <div class="tags">
          <span class="tag live">Diva</span>
          <span class="tag live">CPU</span>
          <span class="tag live">Adobe Analytics</span>
        </div>
        <div class="agent-footer">
          <div class="agent-meta"><strong>Last run:</strong> Predator Drop · Yesterday</div>
          <button class="launch">Launch <span>→</span></button>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- =================== ORCHESTRATOR =================== -->
